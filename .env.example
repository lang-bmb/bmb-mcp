# Chatter MCP Server - Environment Configuration
# Copy this file to .env and fill in your values
# .env is gitignored and should never be committed

# =============================================================================
# AI Provider API Keys (for validation testing)
# =============================================================================

# OpenAI (GPT-4, GPT-4o, etc.)
OPENAI_API_KEY=sk-proj-your-openai-api-key-here
OPENAI_MODEL=gpt-4o

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Google (Gemini)
GOOGLE_API_KEY=your-google-api-key-here
GOOGLE_MODEL=gemini-2.0-flash

# =============================================================================
# BMB Toolchain Paths
# =============================================================================

# Path to BMB compiler executable
BMB_PATH=/usr/local/bin/bmb
# Windows: BMB_PATH=C:\bmb\bin\bmb.exe

# Path to Z3 solver (for contract verification)
Z3_PATH=/usr/local/bin/z3
# Windows: Z3_PATH=C:\z3\bin\z3.exe

# Path to BMB runtime library
BMB_RUNTIME_PATH=/usr/local/lib/bmb/runtime.c

# =============================================================================
# Test Configuration
# =============================================================================

# Test mode: unit, integration, e2e, validation
TEST_MODE=unit

# Enable verbose logging during tests
TEST_VERBOSE=false

# Number of iterations for AI validation tests
VALIDATION_ITERATIONS=5

# Timeout for verification operations (milliseconds)
VERIFICATION_TIMEOUT_MS=5000

# Timeout for compilation operations (milliseconds)
COMPILATION_TIMEOUT_MS=30000

# =============================================================================
# MCP Server Configuration
# =============================================================================

# Server port (for standalone mode)
MCP_PORT=3000

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Log file path (optional)
LOG_FILE=/var/log/chatter.log

# Enable telemetry (opt-in)
TELEMETRY_ENABLED=false

# =============================================================================
# Security Configuration
# =============================================================================

# Rate limiting: max requests per minute
RATE_LIMIT_RPM=60

# Enable strict mode (all security checks)
STRICT_MODE=true

# Allowed file extensions for code input
ALLOWED_EXTENSIONS=.bmb,.rs

# =============================================================================
# Development Configuration
# =============================================================================

# Enable hot reload in development
DEV_HOT_RELOAD=true

# Mock external services (Z3, BMB compiler)
DEV_MOCK_SERVICES=false

# Skip AI provider calls in tests (use cached responses)
DEV_USE_CACHED_RESPONSES=false
